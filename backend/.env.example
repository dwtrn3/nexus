# Server
PORT=3001
NODE_ENV=development
SESSION_SECRET=your-secure-session-secret-here
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://nexus:nexus@postgres:5432/nexus

# Redis
REDIS_URL=redis://redis:6379

# Google OAuth (for Google Sign-In, Gmail, Google Chat)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback
GMAIL_REDIRECT_URI=http://localhost:3001/api/gmail/oauth/callback

# Gmail Pub/Sub (optional, for push notifications)
GMAIL_PUBSUB_TOPIC=projects/YOUR_PROJECT/topics/gmail-notifications

# Slack OAuth
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_REDIRECT_URI=http://localhost:3001/api/slack/oauth/callback

# WhatsApp Business API (Meta)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# Encryption key for stored credentials
ENCRYPTION_KEY=your-32-char-encryption-key-here
